# =============================================================================
# AxiomCraft — Universal Switchboard Configuration
# Copy this file to .env and fill in values for your chosen providers.
# =============================================================================

# -----------------------------------------------------------------------------
# CORE
# -----------------------------------------------------------------------------
SESSION_SECRET=change-me-to-a-random-secret
DATABASE_URL=postgresql://user:password@localhost:5432/axiomcraft
PORT=8080

# Redirect URLs used by all payment providers
PAYMENT_SUCCESS_URL=https://yourdomain.com/success
PAYMENT_CANCEL_URL=https://yourdomain.com/cancel

# -----------------------------------------------------------------------------
# UNIVERSAL SWITCHBOARD — Select active providers
# -----------------------------------------------------------------------------

# Database provider: postgresql | supabase | mongodb | firebase
ACTIVE_DATABASE=postgresql

# Payment provider: stripe | amarpay | lemonsqueezy | paypal | sslcommerz
ACTIVE_PAYMENT=stripe

# =============================================================================
# DATABASE PROVIDER CREDENTIALS
# (Only the variables for ACTIVE_DATABASE are required at runtime)
# =============================================================================

# --- PostgreSQL (default — uses existing Drizzle ORM setup) -----------------
# DATABASE_URL already set above; no additional keys needed.

# --- Supabase ----------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- MongoDB (Atlas Data API) ------------------------------------------------
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/axiomcraft
MONGODB_DB_NAME=axiomcraft
MONGODB_DATA_SOURCE=Cluster0
MONGODB_DATA_API_URL=https://data.mongodb-api.com/app/<app-id>/endpoint/data/v1
MONGODB_DATA_API_KEY=your-mongodb-data-api-key

# --- Firebase / Firestore ----------------------------------------------------
FIREBASE_PROJECT_ID=your-firebase-project-id
# Short-lived OAuth 2.0 bearer token from a service account
FIREBASE_SERVICE_ACCOUNT_TOKEN=your-firebase-service-account-token

# =============================================================================
# PAYMENT PROVIDER CREDENTIALS
# (Only the variables for ACTIVE_PAYMENT are required at runtime)
# =============================================================================

# --- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- AmarPay -----------------------------------------------------------------
AMARPAY_STORE_ID=your-amarpay-store-id
AMARPAY_SIGNATURE_KEY=your-amarpay-signature-key
AMARPAY_SANDBOX=true

# --- LemonSqueezy ------------------------------------------------------------
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_VARIANT_ID=your-variant-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-lemonsqueezy-webhook-secret

# --- PayPal ------------------------------------------------------------------
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
# Set to "false" for production
PAYPAL_SANDBOX=true

# --- SSLCommerz --------------------------------------------------------------
SSLCOMMERZ_STORE_ID=your-sslcommerz-store-id
SSLCOMMERZ_STORE_PASSWORD=your-sslcommerz-store-password
SSLCOMMERZ_IPN_URL=https://yourdomain.com/api/webhook
# Set to "false" for production
SSLCOMMERZ_SANDBOX=true

# =============================================================================
# OPENAI (AI review summaries)
# =============================================================================
OPENAI_API_KEY=sk-...

# =============================================================================
# OBJECT STORAGE (GCS presigned uploads)
# =============================================================================
DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-bucket-id
PRIVATE_OBJECT_DIR=private
PUBLIC_OBJECT_SEARCH_PATHS=public
